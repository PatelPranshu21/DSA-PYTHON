   "source": [
    "# IF ARRAY IS SORTED OR NOT "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "ba662f85-9810-491a-b62e-a3601e567319",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "True\n"
     ]
    }
   ],
   "source": [
    "nums=[3,5,6,8,9,10,12,15]\n",
    "def array_sort(nums):\n",
    "    for i in range(0,len(nums)-1):\n",
    "        if nums[i]>nums[i+1]:\n",
    "            return False\n",
    "    return True        \n",
    "print(array_sort(nums))             "
   ]
  },
